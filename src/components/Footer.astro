---
import FooterToolsList from './FooterToolsList.astro';
import type { Lang } from '../lib/tools/types';

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const year = new Date().getFullYear();

type FooterLink = { label: string; href: string; disabled?: boolean };
type LegalColumn = { heading: string; links: FooterLink[] };

const legalByLang: Record<string, LegalColumn> = {
  de: {
    heading: 'Rechtliches',
    links: [
      { label: 'Datenschutz', href: '#', disabled: true },
      { label: 'Impressum', href: '#', disabled: true },
    ],
  },
  en: {
    heading: 'Legal',
    links: [
      { label: 'Privacy', href: '#', disabled: true },
      { label: 'Imprint', href: '#', disabled: true },
    ],
  },
};
const legal = legalByLang[lang] ?? legalByLang.en!;

const taglineByLang: Record<string, string> = {
  de: 'Schnelle Tools. Kein Upload. Kein Tracking.',
  en: 'Fast tools. No uploads. No tracking.',
};
const tagline = taglineByLang[lang] ?? taglineByLang.en!;

const brandAriaByLang: Record<string, string> = {
  de: 'kittokit — Startseite',
  en: 'kittokit — Homepage',
};
const brandAria = brandAriaByLang[lang] ?? brandAriaByLang.en!;
---
<footer class="site-footer">
  <div class="inner">

    <!-- Brand closing signature -->
    <div class="footer-brand">
      <a class="footer-brand__link" href={`/${lang}`} aria-label={brandAria}>
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20">
            <rect width="24" height="24" rx="6" fill="var(--color-accent)"/>
            <path d="M9,9 L9,6 Q9,5 10,5 L14,5 Q15,5 15,6 L15,9" stroke="var(--color-text)" stroke-width="1.2" fill="none"/>
            <rect x="3" y="9" width="18" height="11" rx="1.5" fill="var(--color-bg)" stroke="var(--color-text)" stroke-width="1"/>
            <rect x="5" y="17" width="2.5" height="2.5" fill="var(--color-text)"/>
            <rect x="8.5" y="12" width="3" height="7.5" fill="var(--color-text)"/>
            <rect x="12.5" y="15" width="2.5" height="4.5" fill="var(--color-text)"/>
            <rect x="16" y="10.5" width="3.5" height="9" fill="var(--color-accent)"/>
          </svg>
        </span>
        <span class="wordmark">kit<em>to</em>kit</span>
      </a>
      <p class="footer-tagline">{tagline}</p>
    </div>

    <!-- Footer nav columns -->
    <div class="footer-cols">
      <FooterToolsList lang={lang as Lang} />

      <section class="col">
        <h2 class="col__heading">{legal.heading}</h2>
        <ul class="col__list">
          {legal.links.map((link) => (
            <li>
              <a
                class="col__link col__link--disabled"
                href={link.href}
                aria-disabled="true"
                tabindex="-1"
              >{link.label}</a>
            </li>
          ))}
        </ul>
      </section>

    </div>

    <!-- Copyright bottom bar -->
    <div class="footer-bottom">
      <span>© {year} kittokit</span>
      <a href="#top" class="footer-bottom__top">Nach oben</a>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-24);
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
  .inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: var(--space-10) var(--space-6) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Brand signature — K mark + wordmark + tagline */
  .footer-brand {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-8);
  }
  .footer-brand__link {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text);
    text-decoration: none;
    transition: opacity var(--dur-fast) var(--ease-out);
  }
  .footer-brand__link:hover {
    opacity: 0.75;
  }
  .footer-brand__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--space-1);
    border-radius: var(--r-sm);
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
  }
  .wordmark {
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
  }
  .wordmark em {
    font-style: normal;
    color: var(--color-accent);
  }
  .footer-tagline {
    margin: 0;
    font-family: var(--font-family-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--tracking-label);
    color: var(--color-text-subtle);
    text-transform: uppercase;
  }

  /* Two-column layout: tools (wider, holds ~8 links split as 2-subcol
     grid inside FooterToolsList) + legal. Removed the near-empty Meta
     column since DE-only launch makes a language list premature. */
  .footer-cols {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
  }
  .col__heading {
    font-size: var(--font-size-small);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--space-3);
  }
  .col__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--font-size-small);
  }
  .col__link {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .col__link:hover {
    color: var(--color-text);
  }
  .col__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--space-1);
    border-radius: var(--r-sm);
  }
  .col__link--disabled {
    color: var(--color-text-subtle);
    pointer-events: none;
    cursor: default;
  }

  /* Copyright bottom strip */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    font-family: var(--font-family-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-subtle);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }
  .footer-bottom__top {
    color: var(--color-text-subtle);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .footer-bottom__top:hover {
    color: var(--color-text);
  }
  .footer-bottom__top:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--space-1);
    border-radius: var(--r-sm);
  }

  @media (max-width: 40rem) {
    .footer-brand {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3);
    }
    .footer-cols {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2);
    }
  }
</style>
