---
import FooterToolsList from './FooterToolsList.astro';
import { t } from '../lib/i18n/strings';
import type { Lang } from '../lib/i18n/lang';

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const langTyped = lang as Lang;
const strings = t(langTyped);
const year = new Date().getFullYear();

type FooterLink = { label: string; href: string; disabled?: boolean };
type LegalColumn = { heading: string; links: FooterLink[] };

const legal: LegalColumn = {
  heading: strings.footer.legalHeading,
  links: [
    { label: strings.footer.privacyLabel, href: `/${lang}${strings.footer.privacyHref}` },
    { label: strings.footer.imprintLabel, href: `/${lang}${strings.footer.imprintHref}` },
  ],
};

const tagline = strings.footer.tagline;
const brandAria = strings.footer.brandAria;
---
<footer class="site-footer">
  <div class="inner">

    <!-- Brand closing signature -->
    <div class="footer-brand">
      <a class="footer-brand__link" href={`/${lang}`} aria-label={brandAria}>
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20">
            <rect width="24" height="24" rx="6" fill="var(--color-text)"/>
            <polyline points="8,7 4,12 8,17" stroke="var(--color-bg)" stroke-width="1.5" fill="none" stroke-linejoin="round" stroke-linecap="round"/>
            <line x1="12" y1="7" x2="12" y2="17" stroke="#F0A066" stroke-width="3" stroke-linecap="round"/>
            <polyline points="20,7 16,12 20,17" stroke="var(--color-bg)" stroke-width="1.5" fill="none" stroke-linejoin="round" stroke-linecap="round"/>
          </svg>
        </span>
        <span class="wordmark">kit<em>to</em>kit</span>
      </a>
      <p class="footer-tagline">{tagline}</p>
    </div>

    <!-- Footer nav columns -->
    <div class="footer-cols">
      <FooterToolsList lang={langTyped} />

      <section class="col">
        <h2 class="col__heading">{legal.heading}</h2>
        <ul class="col__list">
          {legal.links.map((link) => (
            <li>
              <a
                class:list={['col__link', { 'col__link--disabled': link.disabled }]}
                href={link.href}
                aria-disabled={link.disabled ? 'true' : undefined}
                tabindex={link.disabled ? -1 : undefined}
              >{link.label}</a>
            </li>
          ))}
        </ul>
      </section>

    </div>

    <!-- Copyright bottom bar -->
    <div class="footer-bottom">
      <span>© {year} kittokit</span>
      <a href="#top" class="footer-bottom__top">{strings.footer.backToTop}</a>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-24);
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
  .inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: var(--space-10) var(--space-6) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Brand signature — K mark + wordmark + tagline */
  .footer-brand {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-8);
  }
  .footer-brand__link {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text);
    text-decoration: none;
    transition: opacity var(--dur-fast) var(--ease-out);
  }
  .footer-brand__link:hover {
    opacity: 0.75;
  }
  .footer-brand__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--space-1);
    border-radius: var(--r-sm);
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
  }
  .wordmark {
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
  }
  .wordmark em {
    font-style: normal;
    color: var(--color-accent);
  }
  .footer-tagline {
    margin: 0;
    font-family: var(--font-family-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--tracking-label);
    color: var(--color-text-subtle);
    text-transform: uppercase;
  }

  /* Two-column layout: tools (wider, holds ~8 links split as 2-subcol
     grid inside FooterToolsList) + legal. Removed the near-empty Meta
     column since DE-only launch makes a language list premature. */
  .footer-cols {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
  }
  .col__heading {
    font-size: var(--font-size-small);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--space-3);
  }
  .col__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--font-size-small);
  }
  .col__link {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .col__link:hover {
    color: var(--color-text);
  }
  .col__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--space-1);
    border-radius: var(--r-sm);
  }
  .col__link--disabled {
    color: var(--color-text-subtle);
    pointer-events: none;
    cursor: default;
  }

  /* Copyright bottom strip */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    font-family: var(--font-family-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-subtle);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }
  .footer-bottom__top {
    color: var(--color-text-subtle);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .footer-bottom__top:hover {
    color: var(--color-text);
  }
  .footer-bottom__top:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--space-1);
    border-radius: var(--r-sm);
  }

  @media (max-width: 40rem) {
    .footer-brand {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3);
    }
    .footer-cols {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2);
    }
  }
</style>
