---
import FooterToolsList from './FooterToolsList.astro';
import type { Lang } from '../lib/tools/types';

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const year = new Date().getFullYear();

type FooterLink = { label: string; href: string; disabled?: boolean };
type LegalColumn = { heading: string; links: FooterLink[] };

const legalByLang: Record<string, LegalColumn> = {
  de: {
    heading: 'Rechtliches',
    links: [
      { label: 'Datenschutz', href: '#', disabled: true },
      { label: 'Impressum', href: '#', disabled: true },
    ],
  },
  en: {
    heading: 'Legal',
    links: [
      { label: 'Privacy', href: '#', disabled: true },
      { label: 'Imprint', href: '#', disabled: true },
    ],
  },
};
const legal = legalByLang[lang] ?? legalByLang.en!;
const metaHeading = 'Meta';
---
<footer class="site-footer">
  <div class="inner">
    <FooterToolsList lang={lang as Lang} />

    <section class="col">
      <h2 class="col__heading">{legal.heading}</h2>
      <ul class="col__list">
        {legal.links.map((link) => (
          <li>
            <a
              class="col__link col__link--disabled"
              href={link.href}
              aria-disabled="true"
              tabindex="-1"
            >{link.label}</a>
          </li>
        ))}
      </ul>
    </section>

    <section class="col">
      <h2 class="col__heading">{metaHeading}</h2>
      <ul class="col__list">
        <li lang={lang}>Sprache: <span translate="no">{lang.toUpperCase()}</span></li>
        <li>© {year} Konverter</li>
      </ul>
    </section>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-24);
    border-top: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
  }
  .inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }
  .col__heading {
    font-size: var(--font-size-small);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--space-3);
  }
  .col__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--font-size-small);
  }
  .col__link {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .col__link:hover {
    color: var(--color-text);
  }
  .col__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--space-1);
    border-radius: var(--r-sm);
  }
  .col__link--disabled {
    color: var(--color-text-subtle);
    pointer-events: none;
    cursor: default;
  }

  @media (max-width: 40rem) {
    .inner {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
