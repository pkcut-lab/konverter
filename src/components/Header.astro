---
import ThemeToggle from './ThemeToggle.svelte';
import HeaderSearch from './HeaderSearch.svelte';
import { POPULAR_TOOLS } from '../lib/popular-tools';
import { getSlug } from '../lib/slug-map';
import type { Lang } from '../lib/tools/types';

interface Props {
  lang: string;
}
const { lang } = Astro.props;

const searchPlaceholder: Record<string, string> = {
  de: 'Tools durchsuchen',
  en: 'Search tools',
};
const placeholder = searchPlaceholder[lang] ?? searchPlaceholder.en;

type NavItem = { label: string; href: string; disabled?: boolean };
const navByLang: Record<string, NavItem[]> = {
  de: [
    { label: 'Werkzeuge', href: `/${lang}/werkzeuge` },
    { label: 'Über', href: '#', disabled: true },
    { label: 'Sprache', href: '#', disabled: true },
  ],
  en: [
    { label: 'Tools', href: `/${lang}/werkzeuge` },
    { label: 'About', href: '#', disabled: true },
    { label: 'Language', href: '#', disabled: true },
  ],
};
const nav = navByLang[lang] ?? navByLang.en!;

// Beliebt-Bar: resolve slug per current language, drop tools that lack a
// translation for `lang` so links never 404.
const popularLabelByLang: Record<string, string> = {
  de: 'Beliebt',
  en: 'Popular',
};
const popularLabel = popularLabelByLang[lang] ?? popularLabelByLang.en!;

const brandAriaByLang: Record<string, string> = {
  de: 'kittokit — Startseite',
  en: 'kittokit — Homepage',
};
const brandAria = brandAriaByLang[lang] ?? brandAriaByLang.en!;

type PopularEntry = { href: string; label: string; active: boolean };
const currentPath = Astro.url.pathname.replace(/\/$/, '');
const popular: PopularEntry[] = POPULAR_TOOLS.flatMap((p) => {
  const slug = getSlug(p.toolId, lang as Lang);
  const label = p.label[lang as Lang];
  if (!slug || !label) return [];
  const href = `/${lang}/${slug}`;
  return [{ href, label, active: currentPath === href.replace(/\/$/, '') }];
});
---
<header class="site-header" data-pagefind-ignore>
  <div class="inner">
    <a class="brand" href={`/${lang}`} aria-label={brandAria}>
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="26" height="26">
          <rect width="24" height="24" rx="6" fill="var(--color-accent)" />
          <path
            d="M4 5 L9 12 L4 19 M15 5 L20 12 L15 19"
            fill="none"
            stroke="var(--color-bg)"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <circle cx="12" cy="12" r="2" fill="var(--color-bg)"/>
        </svg>
      </span>
      <span class="wordmark">kit<em>to</em>kit</span>
    </a>

    <nav class="nav" aria-label="Hauptnavigation">
      {nav.map((item) => (
        item.disabled ? (
          <a
            class="nav__link nav__link--disabled"
            href={item.href}
            aria-disabled="true"
            tabindex="-1"
          >{item.label}</a>
        ) : (
          <a class="nav__link" href={item.href}>{item.label}</a>
        )
      ))}
    </nav>

    <div class="search-slot">
      <HeaderSearch client:idle lang={lang} placeholder={placeholder} />
    </div>

    <div class="toggle-slot">
      <ThemeToggle client:idle />
    </div>
  </div>

  {popular.length > 0 && (
    <nav class="popular-bar" aria-label={popularLabel}>
      <div class="popular-bar__inner">
        <span class="popular-bar__label">{popularLabel}</span>
        <ul class="popular-bar__list">
          {popular.map((p) => (
            <li>
              <a
                class:list={['popular-tab', p.active && 'popular-tab--active']}
                href={p.href}
                aria-current={p.active ? 'page' : undefined}
              >
                <span class="popular-tab__dot" aria-hidden="true"></span>
                <span class="popular-tab__label">{p.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  )}
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    /* Semi-transparent bg so backdrop-blur shows content scrolling beneath.
       color-mix keeps us token-only without hardcoding rgba values. */
    background: color-mix(in oklch, var(--color-bg) 92%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
  }
  .inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: var(--space-3) var(--space-6);
    display: grid;
    grid-template-columns: auto auto 1fr auto;
    align-items: center;
    gap: var(--space-6);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text);
    text-decoration: none;
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .brand-mark svg {
    display: block;
  }
  .wordmark {
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: var(--tracking-tight);
  }
  .wordmark em {
    font-style: normal;
    color: var(--color-accent);
  }

  .nav {
    display: inline-flex;
    align-items: center;
    gap: var(--space-6);
  }
  .nav__link {
    font-size: var(--font-size-small);
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .nav__link:hover {
    color: var(--color-text);
  }
  .nav__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--space-1);
    border-radius: var(--r-sm);
  }
  .nav__link--disabled {
    color: var(--color-text-subtle);
    pointer-events: none;
    cursor: default;
  }

  .search-slot {
    min-width: 0;
  }
  .toggle-slot {
    display: inline-flex;
  }

  /* ─────────────────────────────────────────────────────────────
     Beliebt-Bar — horizontal row of popular tool tabs.
     Session 3 addition (2026-04-20). Label + dotted tabs + orange
     underline on the currently-active tool. Popularity order is
     hand-curated in src/lib/popular-tools.ts — Phase 2 will
     replace with analytics-driven ranking.
     ───────────────────────────────────────────────────────────── */
  .popular-bar {
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
    overflow: hidden;
  }
  .popular-bar__inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 var(--space-6);
    display: flex;
    align-items: stretch;
    gap: var(--space-4);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .popular-bar__inner::-webkit-scrollbar {
    display: none;
  }
  .popular-bar__label {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    padding-right: var(--space-4);
    border-right: 1px solid var(--color-border);
    font-family: var(--font-family-mono);
    font-size: var(--font-size-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-label-wide);
    text-transform: uppercase;
    color: var(--color-text-subtle);
    white-space: nowrap;
  }
  .popular-bar__list {
    display: inline-flex;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .popular-tab {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-3);
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
    text-decoration: none;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }
  .popular-tab:hover {
    color: var(--color-text);
  }
  .popular-tab:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
    border-radius: var(--r-sm);
  }
  .popular-tab__dot {
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background: var(--color-text-subtle);
    transition: background var(--dur-fast) var(--ease-out);
  }
  .popular-tab:hover .popular-tab__dot {
    background: var(--color-text-muted);
  }
  .popular-tab--active {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
    font-weight: 500;
  }
  .popular-tab--active .popular-tab__dot {
    background: var(--color-accent);
  }

  @media (max-width: 40rem) {
    .inner {
      grid-template-columns: 1fr auto;
      row-gap: var(--space-2);
    }
    .nav {
      display: none;
    }
    .search-slot {
      grid-column: 1 / -1;
      order: 3;
    }
    .popular-bar__inner {
      padding: 0 var(--space-4);
    }
    .popular-bar__label {
      display: none;
    }
  }
</style>
