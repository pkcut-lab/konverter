---
import ThemeToggle from './ThemeToggle.svelte';
import HeaderSearch from './HeaderSearch.svelte';

interface Props {
  lang: string;
}
const { lang } = Astro.props;

const searchPlaceholder: Record<string, string> = {
  de: 'Tools durchsuchen',
  en: 'Search tools',
};
const placeholder = searchPlaceholder[lang] ?? searchPlaceholder.en;

type NavItem = { label: string; href: string; disabled?: boolean };
const navByLang: Record<string, NavItem[]> = {
  de: [
    { label: 'Werkzeuge', href: `/${lang}/` },
    { label: 'Über', href: '#', disabled: true },
    { label: 'Sprache ▾', href: '#', disabled: true },
  ],
  en: [
    { label: 'Tools', href: `/${lang}/` },
    { label: 'About', href: '#', disabled: true },
    { label: 'Language ▾', href: '#', disabled: true },
  ],
};
const nav = navByLang[lang] ?? navByLang.en!;
---
<header class="site-header" data-pagefind-ignore>
  <div class="inner">
    <a class="brand" href={`/${lang}/`}>
      <span class="wordmark">Konverter</span>
    </a>

    <nav class="nav" aria-label="Hauptnavigation">
      {nav.map((item) => (
        item.disabled ? (
          <a
            class="nav__link nav__link--disabled"
            href={item.href}
            aria-disabled="true"
            tabindex="-1"
          >{item.label}</a>
        ) : (
          <a class="nav__link" href={item.href}>{item.label}</a>
        )
      ))}
    </nav>

    <div class="search-slot">
      <HeaderSearch client:load lang={lang} placeholder={placeholder} />
    </div>

    <div class="toggle-slot">
      <ThemeToggle client:load />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }
  .inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: var(--space-3) var(--space-6);
    display: grid;
    grid-template-columns: auto auto 1fr auto;
    align-items: center;
    gap: var(--space-6);
  }
  .brand {
    color: var(--color-text);
    text-decoration: none;
  }
  .wordmark {
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: -0.01em;
  }

  .nav {
    display: inline-flex;
    align-items: center;
    gap: var(--space-6);
  }
  .nav__link {
    font-size: var(--font-size-small);
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .nav__link:hover {
    color: var(--color-text);
  }
  .nav__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--space-1);
    border-radius: var(--r-sm);
  }
  .nav__link--disabled {
    color: var(--color-text-subtle);
    pointer-events: none;
    cursor: default;
  }

  .search-slot {
    min-width: 0;
  }
  .toggle-slot {
    display: inline-flex;
  }

  @media (max-width: 40rem) {
    .inner {
      grid-template-columns: 1fr auto;
      row-gap: var(--space-2);
    }
    .nav {
      display: none;
    }
    .search-slot {
      grid-column: 1 / -1;
      order: 3;
    }
  }
</style>
