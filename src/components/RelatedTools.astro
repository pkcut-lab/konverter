---
// src/components/RelatedTools.astro
//
// Rendert die verwandten Tools als horizontale Tab-Leiste direkt unter
// dem Tool-Bereich. Benutzt seit feat/category-fallback die Fallback-Variante:
// explicit-Slugs first, dann Same-Category-Geschwister bis `minCount` erreicht.
// Wrap ist conditional: null Treffer → kein Markup.
import { resolveRelatedToolsWithFallback } from '../lib/tools/list';
import type { Lang } from '../lib/tools/types';

interface Props {
  lang: Lang;
  ownSlug: string;
  relatedSlugs: readonly string[];
  minCount?: number;
}
const { lang, ownSlug, relatedSlugs, minCount = 3 } = Astro.props;
const tools = await resolveRelatedToolsWithFallback(lang, ownSlug, relatedSlugs, minCount);

const labelByLang: Record<string, string> = {
  de: 'Verwandt',
  en: 'Related',
};
const label = labelByLang[lang] ?? labelByLang.en!;
---
{tools.length > 0 && (
  <nav class="related-bar" aria-label={label}>
    <div class="related-bar__inner">
      <span class="related-bar__label">{label}</span>
      <ul class="related-bar__list">
        {tools.map((t) => (
          <li>
            <a class="related-tab" href={t.href}>
              <span class="related-tab__dot" aria-hidden="true"></span>
              <span class="related-tab__label">{t.shortTitle}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
)}

<style>
  /* Stilzwilling zur Header-.popular-bar: gleiche Tokens, gleiches Muster.
     Border-Top/Bottom grenzt die Leiste optisch vom Tool-Bereich ab,
     ohne eine Karte zu bauen. */
  .related-bar {
    max-width: 60rem;
    width: 100%;
    margin: 0 auto var(--space-16);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .related-bar__inner {
    display: flex;
    align-items: stretch;
    gap: var(--space-4);
    padding: 0 var(--space-2);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .related-bar__inner::-webkit-scrollbar {
    display: none;
  }
  .related-bar__label {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    padding-right: var(--space-4);
    border-right: 1px solid var(--color-border);
    font-family: var(--font-family-mono);
    font-size: var(--font-size-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    white-space: nowrap;
  }
  .related-bar__list {
    display: inline-flex;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .related-tab {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-3);
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
    text-decoration: none;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }
  .related-tab:hover {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
  }
  .related-tab:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
    border-radius: var(--r-sm);
  }
  .related-tab__dot {
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background: var(--color-text-subtle);
    transition: background var(--dur-fast) var(--ease-out);
  }
  .related-tab:hover .related-tab__dot {
    background: var(--color-accent);
  }

  @media (max-width: 40rem) {
    .related-bar {
      margin-bottom: var(--space-12);
    }
    .related-bar__label {
      display: none;
    }
  }
</style>
