---
// src/components/FooterToolsList.astro
import { listToolsForLang } from '../lib/tools/list';
import { getStaticPagePath } from '../lib/static-page-slugs';
import { t } from '../lib/i18n/strings';
import type { Lang } from '../lib/i18n/lang';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const strings = t(lang);

const CAP = 8;
const tools = await listToolsForLang(lang);
const visible = tools.slice(0, CAP);
const overflow = Math.max(0, tools.length - CAP);

const heading = strings.header.nav.tools;
const overflowLabel = strings.footer.moreTools.replace('{count}', String(overflow));
const allToolsHref = getStaticPagePath('tools', lang);
---
<section>
  <h2>{heading}</h2>
  <ul>
    {visible.map((t) => (
      <li>
        <a href={t.href}>
          <span class="tool-title">{t.shortTitle}</span>
          <span class="tool-tagline">{t.tagline}</span>
        </a>
      </li>
    ))}
    {overflow > 0 && (
      <li class="overflow">
        {/* NBSP zwischen `+` und Zahl damit es nicht umbricht */}
        <a href={allToolsHref}>{overflowLabel}</a>
      </li>
    )}
  </ul>
</section>

<style>
  /* h2 muss hier wieder gesetzt werden — Astro scoped-styles in Footer.astro erreichen die h2 dieser Component nicht, da sie zu einem anderen Scope-Tree gehört. Werte = Visual-Parität zu Rechtliches/Meta-Headings (Footer.astro:50-54). */
  h2 {
    font-size: var(--font-size-small);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--space-3);
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4) var(--space-6);
    font-size: var(--font-size-small);
  }
  li {
    min-width: 0;
  }
  .overflow {
    grid-column: 1 / -1;
  }
  @media (max-width: 40rem) {
    ul {
      grid-template-columns: 1fr;
    }
  }
  a {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }
  /* Bold tool name vs. muted tagline creates a clear hierarchy in the
     dense 2-column footer grid. Mirrors the editorial pattern from the
     tool-overview page (werkzeuge.astro) at a smaller scale. */
  .tool-title {
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: var(--tracking-snug);
  }
  .tool-tagline {
    color: var(--color-text-subtle);
    line-height: 1.4;
  }
  a:hover .tool-title,
  a:focus-visible .tool-title {
    color: var(--color-accent);
  }
  a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: var(--r-sm);
  }
  .overflow a {
    color: var(--color-text-muted);
  }
  .overflow a:hover,
  .overflow a:focus-visible {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: var(--underline-offset);
  }
  .overflow {
    margin-top: var(--space-2);
  }
  @media (prefers-reduced-motion: reduce) {
    a { transition: none; }
  }
</style>
