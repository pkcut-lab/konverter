---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Converter from '../../components/tools/Converter.svelte';
import { meterZuFuss } from '../../lib/tools/meter-zu-fuss';
import { getSlug } from '../../lib/slug-map';
import type { ToolConfig } from '../../lib/tools/schemas';

/**
 * Add every new tool here alongside its slug-map entry. Session 6 extracts
 * this to `src/lib/tool-registry.ts` so adding a tool is a single-file change.
 */
const toolRegistry: Record<string, ToolConfig> = {
  'meter-to-feet': meterZuFuss,
};

export async function getStaticPaths() {
  const entries = await getCollection('tools');
  return entries.map((entry) => {
    const slug = getSlug(entry.data.toolId, entry.data.language);
    if (!slug) {
      throw new Error(
        `No slug-map entry for toolId="${entry.data.toolId}", ` +
          `lang="${entry.data.language}". Add it to src/lib/slug-map.ts.`,
      );
    }
    return {
      params: { lang: entry.data.language, slug },
      props: { entry, slug },
    };
  });
}

type Props = { entry: CollectionEntry<'tools'>; slug: string };
const { entry, slug } = Astro.props;
const config = toolRegistry[entry.data.toolId];

if (!config) {
  throw new Error(
    `No tool config registered for toolId="${entry.data.toolId}". ` +
      `Add an entry to src/pages/[lang]/[slug].astro:toolRegistry.`,
  );
}

if (config.type !== 'converter') {
  throw new Error(
    `Session 5 only supports type="converter", got type="${config.type}" ` +
      `for toolId="${entry.data.toolId}". Add a branch in [slug].astro.`,
  );
}

const { Content } = await entry.render();
---
<BaseLayout
  lang={entry.data.language}
  title={entry.data.title}
  description={entry.data.metaDescription}
  pathWithoutLang={`/${slug}`}
>
  <header class="tool-hero">
    <h1>{entry.data.title}</h1>
    <p class="tagline">{entry.data.tagline}</p>
    <div class="tool-ui">
      <Converter config={config} client:load />
    </div>
  </header>

  {/* Phase 2 aktiviert AdSense — der Placeholder reserviert den Platz jetzt
      schon, damit späteres Einblenden keinen CLS erzeugt. aria-hidden, weil
      bis dahin keine sinnvolle Information drinsteht. */}
  <aside class="ad-slot-placeholder" aria-hidden="true">
    <span>Anzeigenplatz</span>
  </aside>

  <article class="tool-article">
    <p class="intro">{entry.data.intro}</p>

    <h2>Wie benutzt du den Konverter?</h2>
    <ol class="how">
      {entry.data.howToUse.map((step) => <li>{step}</li>)}
    </ol>

    <Content />
  </article>
</BaseLayout>

<style>
  .tool-hero {
    max-width: 40rem;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .tool-hero h1 {
    margin: 0;
    font-size: var(--font-size-h1);
    line-height: 1.15;
  }
  .tool-hero .tagline {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--font-size-body);
  }
  .tool-ui {
    margin-top: var(--space-4);
    text-align: left;
  }

  .ad-slot-placeholder {
    max-width: 42rem;
    margin: var(--space-12) auto;
    min-height: 6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--color-border);
    border-radius: var(--r-md);
    color: var(--color-text-muted);
    font-size: var(--font-size-small);
    letter-spacing: 0.02em;
  }

  .tool-article {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--color-text);
    line-height: 1.65;
    font-size: var(--font-size-body);
  }
  .tool-article .intro {
    font-size: 1.125rem;
    color: var(--color-text);
    margin: 0 0 var(--space-8) 0;
  }
  .tool-article h2 {
    margin-top: var(--space-12);
    margin-bottom: var(--space-3);
    font-size: var(--font-size-h2);
    line-height: 1.25;
  }
  .tool-article h2:first-of-type {
    margin-top: 0;
  }
  .tool-article .how {
    padding-left: var(--space-6);
    margin: 0 0 var(--space-6) 0;
  }
  .tool-article .how li {
    margin-bottom: var(--space-2);
  }

  /* TODO(session-6): extract these prose rules into a `.prose` utility in
     global.css — they will duplicate across every tool page. */
  .tool-article :global(h3) {
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
    font-size: var(--font-size-h3);
  }
  .tool-article :global(p) {
    margin: 0 0 var(--space-4) 0;
  }
  .tool-article :global(ul),
  .tool-article :global(ol) {
    padding-left: var(--space-6);
    margin: 0 0 var(--space-4) 0;
  }
  .tool-article :global(li) {
    margin-bottom: var(--space-1);
  }
  .tool-article :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-4) 0 var(--space-6) 0;
    font-size: var(--font-size-small);
  }
  .tool-article :global(th),
  .tool-article :global(td) {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    text-align: left;
  }
  .tool-article :global(th) {
    background: var(--color-surface);
    font-weight: 600;
  }
  .tool-article :global(code) {
    font-family: var(--font-family-mono);
    font-size: 0.92em;
    background: var(--color-surface);
    padding: 0 var(--space-1);
    border-radius: var(--r-sm);
  }
  .tool-article :global(strong) {
    color: var(--color-text);
  }
  .tool-article :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  @media (max-width: 40rem) {
    .tool-hero h1 {
      font-size: 1.875rem;
    }
    .ad-slot-placeholder {
      margin: var(--space-8) auto;
      min-height: 5rem;
    }
  }
</style>
