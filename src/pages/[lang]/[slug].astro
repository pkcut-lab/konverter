---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Converter from '../../components/tools/Converter.svelte';
import FileTool from '../../components/tools/FileTool.svelte';
import ColorConverter from '../../components/tools/ColorConverter.svelte';
import RelatedTools from '../../components/RelatedTools.astro';
import YouMightAlsoLike from '../../components/YouMightAlsoLike.astro';
import { getToolConfig } from '../../lib/tool-registry';
import { getSlug } from '../../lib/slug-map';
import { buildToolJsonLd } from '../../lib/seo/tool-jsonld';

const componentByType = {
  converter: Converter,
  'file-tool': FileTool,
  formatter: ColorConverter,
} as const;

export async function getStaticPaths() {
  const entries = await getCollection('tools');
  // Types that have a Svelte component in componentByType. Defined inline
  // because Astro isolates getStaticPaths from page-level consts.
  const routableTypes = new Set(['converter', 'file-tool', 'formatter']);
  return entries
    .filter((entry) => {
      const slug = getSlug(entry.data.toolId, entry.data.language);
      const config = slug ? getToolConfig(entry.data.toolId) : undefined;
      // Skip content entries whose toolId has no registry config or no component
      // yet. This allows data-only tools (e.g. generator type without Generator.svelte)
      // to exist in the content collection without breaking the build.
      return slug && config && routableTypes.has(config.type);
    })
    .map((entry) => {
      const slug = getSlug(entry.data.toolId, entry.data.language)!;
      return {
        params: { lang: entry.data.language, slug },
        props: { entry, slug },
      };
    });
}

type Props = { entry: CollectionEntry<'tools'>; slug: string };
const { entry, slug } = Astro.props;
const config = getToolConfig(entry.data.toolId);

if (!config) {
  throw new Error(
    `No tool config registered for toolId="${entry.data.toolId}". ` +
      `Add an entry to src/lib/tool-registry.ts.`,
  );
}

if (!(config.type in componentByType)) {
  throw new Error(
    `[slug].astro has no component mapped for type="${config.type}" ` +
      `(toolId="${entry.data.toolId}"). Add an entry to componentByType.`,
  );
}

const { Content } = await entry.render();

// Default privacy-eyebrow: every client-side tool gets a trust signal above
// its H1 unless the content file explicitly overrides via frontmatter.eyebrow.
// Because all tools on this site run fully in the browser (Spec §7, pure-client
// or ML-worker fallback), the message is universal. Content authors can still
// override for special cases (e.g., a deliberately privacy-highlighting pill).
const defaultEyebrowByLang: Record<string, string> = {
  de: 'Läuft lokal · kein Upload',
  en: 'Runs local · no upload',
};
const eyebrowText =
  entry.data.eyebrow ?? defaultEyebrowByLang[entry.data.language] ?? defaultEyebrowByLang.en!;

const jsonLd = buildToolJsonLd(
  {
    toolId: entry.data.toolId,
    lang: entry.data.language,
    title: entry.data.title,
    description: entry.data.metaDescription,
    category: entry.data.category,
    faq: entry.data.faq ?? [],
    steps: (entry.data.howToUse ?? []).map((text, i) => ({
      title: `Schritt ${i + 1}`,
      description: text,
    })),
  },
  Astro.url.href,
);
---
<BaseLayout
  lang={entry.data.language}
  title={entry.data.title}
  description={entry.data.metaDescription}
  pathWithoutLang={`/${slug}`}
>
  {jsonLd.map((block) => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(block)} />
  ))}
  <div class="tool-page">
    <header class="tool-hero">
      <span class="eyebrow">
        <span class="eyebrow__dot" aria-hidden="true"></span>
        {eyebrowText}
      </span>
      {entry.data.headingHtml
        ? <h1 set:html={entry.data.headingHtml} />
        : <h1>{entry.data.title}</h1>
      }
      <p class="tagline">{entry.data.tagline}</p>
    </header>

    <div class:list={['tool-main', entry.data.aside && 'tool-main--with-aside']}>
      <div class="tool-main__primary">
        <section
          class:list={['tool-section', config.type === 'file-tool' && 'tool-section--wide']}
          aria-label="Konverter"
        >
          {config.type === 'converter' && (
            <Converter
              config={config}
              locale={entry.data.language === 'de' ? 'de-DE' : entry.data.language}
              client:load
            />
          )}
          {config.type === 'file-tool' && <FileTool config={config} client:load />}
          {config.type === 'formatter' && <ColorConverter config={config} client:load />}
        </section>

        {entry.data.kbdHints && entry.data.kbdHints.length > 0 && (
          <div class="kbd-hints" aria-hidden="true">
            {entry.data.kbdHints.map((hint) => (
              <kbd class="kbd-hint">
                <span class="kbd-hint__key">{hint.key}</span>
                <span class="kbd-hint__label">{hint.label}</span>
              </kbd>
            ))}
          </div>
        )}
      </div>

      {entry.data.aside && (
        <aside class="tool-aside" aria-labelledby="tool-aside-heading">
          <section class="tool-aside__steps">
            <h2 id="tool-aside-heading">So funktioniert es</h2>
            <ol>
              {entry.data.aside.steps.map((step, i) => (
                <li>
                  <span class="tool-aside__step-number">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <div class="tool-aside__step-body">
                    <h3>{step.title}</h3>
                    <p>{step.description}</p>
                  </div>
                </li>
              ))}
            </ol>
          </section>
          <section class="tool-aside__privacy" aria-labelledby="tool-aside-privacy-heading">
            <h3 id="tool-aside-privacy-heading">Datenschutz</h3>
            <p>{entry.data.aside.privacy}</p>
          </section>
        </aside>
      )}
    </div>

    <RelatedTools
      lang={entry.data.language}
      ownSlug={Astro.params.slug!}
      relatedSlugs={entry.data.relatedTools}
    />

    {/* Phase 2 aktiviert AdSense — der Platzhalter reserviert den Platz jetzt
        schon, damit späteres Einblenden keinen CLS erzeugt. aria-hidden, weil
        bis dahin keine sinnvolle Information drinsteht. */}
    <aside class="ad-slot-placeholder" aria-hidden="true">
      <span>Anzeigenplatz</span>
    </aside>

    <article class="tool-article">
      <p class="intro">{entry.data.intro}</p>

      <header class="section-head">
        <span class="section-head__label">01 — Anleitung</span>
        <h2 class="section-head__title">
          Wie benutzt du <em>den Konverter</em>?
        </h2>
      </header>
      <ol class="how">
        {entry.data.howToUse.map((step) => <li>{step}</li>)}
      </ol>

      <div class="prose tool-article__prose">
        <Content />
      </div>
    </article>

    <YouMightAlsoLike
      lang={entry.data.language}
      currentToolId={entry.data.toolId}
      excludeSlugs={entry.data.relatedTools}
    />
  </div>
</BaseLayout>

<style>
  .tool-page {
    display: flex;
    flex-direction: column;
    padding-top: var(--space-12);
  }

  .tool-hero {
    max-width: 56rem;
    margin: 0 auto var(--space-12);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
  }
  .tool-hero h1 {
    margin: 0;
    /* Editorial scale — Single-Line-Ziel auf Desktop. Max 3.5rem (56px)
       hält den H1 einzeilig bei typischen Tool-Titeln und verhindert,
       dass der Playfair-<em>-Accent die Zeile sprengt. */
    font-size: clamp(2rem, 1rem + 2vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    font-weight: 600;
    text-wrap: balance;
  }
  .tool-hero .tagline {
    margin: 0;
    max-width: 34rem;
    color: var(--color-text-muted);
    font-size: 1.0625rem;
    line-height: 1.55;
  }

  /* §5 Aside-Slot-Primitive: .tool-main wraps .tool-section plus optional .tool-aside.
     Solange kein Aside gerendert wird (kein aside-Frontmatter), bleibt alles zentriert
     innerhalb der 60rem und sieht visuell identisch zum vorherigen Single-Column-Zustand aus. */
  .tool-main {
    max-width: 60rem;
    width: 100%;
    /* Abstand nach unten knapp halten — die Related-Bar soll direkt unter dem
       Tool sitzen, damit der Nutzer nach dem Konvertieren die nächste Option
       sofort sieht. Größerer Abstand kommt erst nach der Related-Bar. */
    margin: 0 auto var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .tool-main__primary {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    min-width: 0;
  }
  .tool-section {
    max-width: 34rem;
    width: 100%;
    margin: 0 auto;
  }
  /* FileTool braucht mehr horizontale Breite als prose — die 3-Preset-
     Segmentreihe + MIME-Pill-Strip passen nicht in 34rem (würden unschön
     umbrechen). 48rem matcht die Template-Settings-Card-Breite bei 1920px
     und bleibt unter dem 60rem-tool-main-Cap. Converter-Tools bleiben 34rem. */
  .tool-section--wide {
    max-width: 48rem;
  }

  @media (min-width: 60rem) {
    .tool-main--with-aside {
      display: grid;
      grid-template-columns: minmax(0, 34rem) minmax(0, 20rem);
      gap: var(--space-6);
      align-items: start;
    }
    .tool-main--with-aside .tool-section {
      margin: 0;
    }
  }

  /* Aside-Slot (§4 Card Variant: Aside-Slot). Base-Card-Styling + non-interaktiv. */
  .tool-aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--r-md);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
  }
  .tool-aside__steps h2 {
    margin: 0 0 var(--space-5) 0;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    color: var(--color-text);
    text-wrap: balance;
  }
  .tool-aside__steps ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .tool-aside__steps li {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
  }
  .tool-aside__step-number {
    flex: 0 0 auto;
    font-family: var(--font-family-mono);
    font-size: var(--font-size-small);
    font-variant-numeric: tabular-nums;
    color: var(--color-text-subtle);
    letter-spacing: 0.02em;
  }
  .tool-aside__step-body {
    min-width: 0;
  }
  .tool-aside__step-body h3 {
    margin: 0 0 var(--space-1) 0;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }
  .tool-aside__step-body p {
    margin: 0;
    font-size: var(--font-size-small);
    line-height: 1.55;
    color: var(--color-text-muted);
  }
  .tool-aside__privacy {
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }
  .tool-aside__privacy h3 {
    margin: 0 0 var(--space-3) 0;
    font-family: var(--font-family-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }
  .tool-aside__privacy p {
    margin: 0;
    font-size: var(--font-size-small);
    line-height: 1.55;
    color: var(--color-text-muted);
  }

  /* Kbd-Hint-Row (§4 Card Variant: Kbd-Hint-Row). Passive Shortcut-Hinweise. */
  .kbd-hints {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
  }
  .kbd-hint {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-surface);
    font-family: var(--font-family-mono);
    font-size: 0.75rem;
  }
  .kbd-hint__key {
    font-weight: 500;
    color: var(--color-text);
  }
  .kbd-hint__label {
    color: var(--color-text-muted);
  }
  @media (min-width: 60rem) {
    .kbd-hints {
      justify-content: flex-start;
    }
  }

  .ad-slot-placeholder {
    max-width: 42rem;
    width: 100%;
    margin: 0 auto var(--space-16);
    min-height: 5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--color-border);
    border-radius: var(--r-md);
    background: var(--color-surface);
    color: var(--color-text-subtle);
    font-size: var(--font-size-small);
    letter-spacing: 0.04em;
  }

  .tool-article {
    max-width: 42rem;
    width: 100%;
    margin: 0 auto;
    /* Kein padding-bottom — die .you-might-Strip setzt ihr eigenes top-padding
       und einen border-top, der die visuelle Trennung übernimmt. */
    padding-bottom: var(--space-8);
  }
  .tool-article .intro {
    font-size: 1.125rem;
    line-height: 1.55;
    color: var(--color-text);
    margin: 0 0 var(--space-12) 0;
  }
  .tool-article h2 {
    margin: 0 0 var(--space-6) 0;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .how {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-16) 0;
    counter-reset: how-step;
  }
  .how li {
    counter-increment: how-step;
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    line-height: 1.6;
  }
  .how li::before {
    content: counter(how-step, decimal-leading-zero);
    flex: 0 0 auto;
    min-width: 2.5ch;
    font-family: var(--font-family-mono);
    font-size: var(--font-size-small);
    font-variant-numeric: tabular-nums;
    color: var(--color-text-subtle);
    letter-spacing: 0.02em;
  }

  .tool-article__prose {
    margin-top: var(--space-16);
  }

  @media (max-width: 40rem) {
    .tool-page {
      padding-top: var(--space-8);
    }
    .tool-hero {
      margin-bottom: var(--space-8);
      gap: var(--space-4);
    }
    .tool-main {
      margin-bottom: var(--space-16);
    }
    .ad-slot-placeholder {
      margin-bottom: var(--space-12);
      min-height: 4.5rem;
    }
    .tool-article .intro {
      margin-bottom: var(--space-8);
      font-size: 1.0625rem;
    }
    .how {
      margin-bottom: var(--space-12);
    }
    .tool-article__prose {
      margin-top: var(--space-12);
    }
    .tool-article {
      padding-bottom: var(--space-4);
    }
  }
</style>
