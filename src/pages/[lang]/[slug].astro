---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Converter from '../../components/tools/Converter.svelte';
import FileTool from '../../components/tools/FileTool.svelte';
import ColorConverter from '../../components/tools/ColorConverter.svelte';
import Formatter from '../../components/tools/Formatter.svelte';
import BildDiffTool from '../../components/tools/BildDiffTool.svelte';
import QrCodeGeneratorTool from '../../components/tools/QrCodeGeneratorTool.svelte';
import ContrastCheckerTool from '../../components/tools/ContrastCheckerTool.svelte';
import RegexTesterTool from '../../components/tools/RegexTesterTool.svelte';
import MehrwertsteuerRechnerTool from '../../components/tools/MehrwertsteuerRechnerTool.svelte';
import StundenlohnJahresgehaltTool from '../../components/tools/StundenlohnJahresgehaltTool.svelte';
import TilgungsplanRechnerTool from '../../components/tools/TilgungsplanRechnerTool.svelte';
import BruttoNettoRechnerTool from '../../components/tools/BruttoNettoRechnerTool.svelte';
import KreditrechnerTool from '../../components/tools/KreditrechnerTool.svelte';
import RabattRechnerTool from '../../components/tools/RabattRechnerTool.svelte';
import ZinsrechnerTool from '../../components/tools/ZinsrechnerTool.svelte';
import ZinseszinsRechnerTool from '../../components/tools/ZinseszinsRechnerTool.svelte';
import RoiRechnerTool from '../../components/tools/RoiRechnerTool.svelte';
import SkontoRechnerTool from '../../components/tools/SkontoRechnerTool.svelte';
import CashflowRechnerTool from '../../components/tools/CashflowRechnerTool.svelte';
import LeasingFaktorRechnerTool from '../../components/tools/LeasingFaktorRechnerTool.svelte';
import ErbschaftsteuerRechnerTool from '../../components/tools/ErbschaftsteuerRechnerTool.svelte';
import Comparer from '../../components/tools/Comparer.svelte';
import Analyzer from '../../components/tools/Analyzer.svelte';
import Generator from '../../components/tools/Generator.svelte';
import Validator from '../../components/tools/Validator.svelte';
import WebcamBlurTool from '../../components/tools/WebcamBlurTool.svelte';
import VideoHintergrundEntfernenTool from '../../components/tools/VideoHintergrundEntfernenTool.svelte';
import KiTextDetektorTool from '../../components/tools/KiTextDetektorTool.svelte';
import KiBildDetektorTool from '../../components/tools/KiBildDetektorTool.svelte';
import AudioTranskriptionTool from '../../components/tools/AudioTranskriptionTool.svelte';
import PdfZusammenfuehrenTool from '../../components/tools/PdfZusammenfuehrenTool.svelte';
import PdfAufteilenTool from '../../components/tools/PdfAufteilenTool.svelte';
import PdfZuJpgTool from '../../components/tools/PdfZuJpgTool.svelte';
import PdfPasswortTool from '../../components/tools/PdfPasswortTool.svelte';
import ToolStats from '../../components/ToolStats.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import YouMightAlsoLike from '../../components/YouMightAlsoLike.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getToolConfig, hasTool } from '../../lib/tool-registry';
import { getSlug } from '../../lib/slug-map';
import { ACTIVE_LANGUAGES, type ActiveLanguage } from '../../lib/hreflang';
import { buildToolJsonLd } from '../../lib/seo/tool-jsonld';
import { getAsideDefault } from '../../lib/content/aside-defaults';
import { getStaticPagePath } from '../../lib/static-page-slugs';
import { t } from '../../lib/i18n/strings';
import { listToolsForLang } from '../../lib/tools/list';
import { computeRelatedTools } from '../../lib/related-tools';

// Tool-ids that need a specialised formatter UI. Everything else with
// `type: 'formatter'` falls through to the generic textarea Formatter.
// Keeps config.id out of the generic components (CONVENTIONS.md §Tool-
// Components) — the switch lives at the route layer.
const HEX_COLOR_TOOL_ID = 'hex-to-rgb';
const IMAGE_DIFF_TOOL_ID = 'image-diff';
const QR_GENERATOR_TOOL_ID = 'qr-code-generator';
const CONTRAST_CHECKER_TOOL_ID = 'contrast-checker';
const REGEX_TESTER_TOOL_ID = 'regex-tester';
const VAT_CALCULATOR_TOOL_ID = 'vat-calculator';
const HOURLY_ANNUAL_TOOL_ID = 'hourly-to-annual';
const AMORTIZATION_TOOL_ID = 'amortization-calculator';
const GROSS_NET_TOOL_ID = 'gross-net-calculator';
const LOAN_CALCULATOR_TOOL_ID = 'loan-calculator';
const DISCOUNT_CALCULATOR_TOOL_ID = 'discount-calculator';
const INTEREST_CALCULATOR_TOOL_ID = 'interest-calculator';
const COMPOUND_INTEREST_TOOL_ID = 'compound-interest-calculator';
const ROI_CALCULATOR_TOOL_ID = 'roi-calculator';
const CASH_DISCOUNT_TOOL_ID = 'cash-discount-calculator';
const CASH_FLOW_TOOL_ID = 'cash-flow-calculator';
const LEASING_FACTOR_TOOL_ID = 'leasing-factor-calculator';
const INHERITANCE_TAX_TOOL_ID = 'inheritance-tax-calculator';
const CUSTOM_FORMATTER_IDS = new Set<string>([
  HEX_COLOR_TOOL_ID,
  IMAGE_DIFF_TOOL_ID,
  QR_GENERATOR_TOOL_ID,
  CONTRAST_CHECKER_TOOL_ID,
  VAT_CALCULATOR_TOOL_ID,
  HOURLY_ANNUAL_TOOL_ID,
  AMORTIZATION_TOOL_ID,
  GROSS_NET_TOOL_ID,
  LOAN_CALCULATOR_TOOL_ID,
  DISCOUNT_CALCULATOR_TOOL_ID,
  INTEREST_CALCULATOR_TOOL_ID,
  COMPOUND_INTEREST_TOOL_ID,
  ROI_CALCULATOR_TOOL_ID,
  CASH_DISCOUNT_TOOL_ID,
  CASH_FLOW_TOOL_ID,
  LEASING_FACTOR_TOOL_ID,
  INHERITANCE_TAX_TOOL_ID,
  'ki-text-detektor',
  'ki-bild-detektor',
  'audio-transkription',
  'pdf-merge',
  'pdf-split',
  'pdf-to-jpg',
  'pdf-password',
]);

const WEBCAM_BLUR_TOOL_ID = 'webcam-blur';
const VIDEO_BG_REMOVE_TOOL_ID = 'video-bg-remove';

const componentByType = {
  converter: Converter,
  'file-tool': FileTool,
  formatter: Formatter,
  comparer: Comparer,
  analyzer: Analyzer,
  generator: Generator,
  validator: Validator,
  interactive: WebcamBlurTool,
} as const;

export async function getStaticPaths() {
  const entries = await getCollection('tools');
  // Types that have a Svelte component in componentByType. Defined inline
  // because Astro isolates getStaticPaths from page-level consts.
  const routableTypes = new Set([
    'converter',
    'file-tool',
    'formatter',
    'comparer',
    'analyzer',
    'generator',
    'validator',
    'interactive',
  ]);

  // Resolve every candidate entry's config in parallel so SSG builds don't
  // serialise module loads across 1000+ tools. tool-registry is lazy now
  // (see `src/lib/tool-registry.ts` docstring) — calling `getToolConfig` for
  // each entry only loads that entry's config module, not all 44+.
  const resolved = await Promise.all(
    entries.map(async (entry) => {
      const slug = getSlug(entry.data.toolId, entry.data.language);
      if (!slug || !hasTool(entry.data.toolId)) return null;
      const config = await getToolConfig(entry.data.toolId);
      if (!config || !routableTypes.has(config.type)) return null;
      return { entry, slug };
    }),
  );

  return resolved
    .filter((r): r is { entry: (typeof entries)[number]; slug: string } => r !== null)
    .map(({ entry, slug }) => ({
      params: { lang: entry.data.language, slug },
      props: { entry, slug },
    }));
}

type Props = { entry: CollectionEntry<'tools'>; slug: string };
const { entry, slug } = Astro.props;
const config = await getToolConfig(entry.data.toolId);
const strings = t(entry.data.language);

if (!config) {
  throw new Error(
    `No tool config registered for toolId="${entry.data.toolId}". ` +
      `Add an entry to src/lib/tool-registry.ts.`,
  );
}

if (!(config.type in componentByType)) {
  throw new Error(
    `[slug].astro has no component mapped for type="${config.type}" ` +
      `(toolId="${entry.data.toolId}"). Add an entry to componentByType.`,
  );
}

const { Content } = await entry.render();

// T3.1 hreflang fix: resolve per-language paths so EN page gets /en/meter-to-feet
// not /en/meter-zu-fuss. Current language uses the routed slug directly; other
// languages are looked up from slug-map. BaseLayout.buildHreflangLinks accepts
// a lang→path record.
const currentLang = entry.data.language as ActiveLanguage;
const pathByLang: Partial<Record<ActiveLanguage, string>> = {
  [currentLang]: `/${slug}`,
  ...Object.fromEntries(
    (ACTIVE_LANGUAGES
      .filter((l) => l !== currentLang)
      .map((l) => {
        const s = getSlug(entry.data.toolId, l);
        return s !== undefined ? ([l, `/${s}` as const] as [ActiveLanguage, string]) : null;
      })
      .filter(Boolean) as Array<[ActiveLanguage, string]>),
  ),
};

// T3.6 breadcrumb items
const breadcrumbItems = [
  { label: strings.breadcrumbHome, href: `/${entry.data.language}` },
  { label: strings.breadcrumbTools, href: getStaticPagePath('tools', entry.data.language as ActiveLanguage) },
  { label: entry.data.title },
];

// T3.3 computed related tools for in-article block (category proximity)
const allToolsForLang = await listToolsForLang(entry.data.language as 'de' | 'en');
const computedRelated = computeRelatedTools(
  entry.data.toolId,
  entry.data.category,
  allToolsForLang,
  5,
).filter((t) => !entry.data.relatedTools?.includes(t.href.split('/').pop()!));

// Per-tool OG card: cards are generated keyed by the DE slug.
// For all languages, resolve the DE slug via toolId and check for the file.
const deSlug = getSlug(entry.data.toolId, 'de');
const ogCardExists =
  deSlug !== undefined &&
  existsSync(resolve(process.cwd(), 'public', 'og', 'tools', `${deSlug}.webp`));
const ogImagePath = ogCardExists ? `/og/tools/${deSlug}.webp` : undefined;
const ogAvifExists =
  deSlug !== undefined &&
  existsSync(resolve(process.cwd(), 'public', 'og', 'tools', `${deSlug}.avif`));
const ogAvifPath = ogAvifExists ? `/og/tools/${deSlug}.avif` : undefined;

// X.7 — Pagefind: popular tool IDs get weight=5 on the article wrapper so
// frequently-searched tools rank above alphabetical equals. List mirrors
// POPULAR_TOOLS in popular-tools.ts (kept inline to avoid a runtime import
// at SSG build — changes here should stay in sync with that file).
const POPULAR_TOOL_IDS = new Set([
  'hevc-to-h264', 'remove-background', 'png-jpg-to-webp',
  'meter-to-feet', 'celsius-to-fahrenheit', 'km-to-mile',
]);
const pagefindArticleWeight = POPULAR_TOOL_IDS.has(entry.data.toolId) ? '5' : undefined;

// X.4 — LCP hero preload. Heroes don't exist yet (0/72 public/heroes/tools/).
// Code is wired so adding hero images automatically activates the preload.
const heroExists =
  deSlug !== undefined &&
  existsSync(resolve(process.cwd(), 'public', 'heroes', 'tools', `${deSlug}.webp`));
const heroImagePath = heroExists ? `/heroes/tools/${deSlug}.webp` : undefined;

// Default privacy-eyebrow: every client-side tool gets a trust signal above
// its H1 unless the content file explicitly overrides via frontmatter.eyebrow.
// Because all tools on this site run fully in the browser (Spec §7, pure-client
// or ML-worker fallback), the message is universal. Content authors can still
// override for special cases (e.g., a deliberately privacy-highlighting pill).
const defaultEyebrowByLang: Record<string, string> = {
  de: 'Läuft lokal · kein Upload',
  en: 'Runs local · no upload',
};
const eyebrowText =
  entry.data.eyebrow ?? defaultEyebrowByLang[entry.data.language] ?? defaultEyebrowByLang.en!;

// Merge: content-file aside wins over category default.
// This means every tool gets the accordion — no per-tool content needed.
const resolvedAside = entry.data.aside ?? getAsideDefault(config.type, entry.data.language) ?? null;

const jsonLd = buildToolJsonLd(
  {
    toolId: entry.data.toolId,
    lang: entry.data.language,
    title: entry.data.title,
    description: entry.data.metaDescription,
    category: entry.data.category,
    toolType: config.type,
    faq: entry.data.faq ?? [],
    // Prefer aside.steps (titled steps) over howToUse (plain strings) for HowTo schema.
    steps: resolvedAside?.steps ?? (entry.data.howToUse ?? []).map((text: string, i: number) => ({
      title: `${strings.stepPrefix} ${i + 1}`,
      description: text,
    })),
    datePublished: entry.data.datePublished,
    dateModified: entry.data.dateModified,
    ...(entry.data.featureList && { featureList: entry.data.featureList }),
    ...(deSlug !== undefined && { heroSlug: deSlug }),
  },
  Astro.url.href,
);

// Format dateModified for UI stamp
const dateModifiedFormatted = entry.data.dateModified
  ? new Intl.DateTimeFormat(
      entry.data.language === 'de' ? 'de-DE' : 'en-US',
      { year: 'numeric', month: '2-digit', day: '2-digit', timeZone: 'UTC' },
    ).format(new Date(entry.data.dateModified + 'T00:00:00Z'))
  : null;
---
<BaseLayout
  lang={entry.data.language}
  title={entry.data.title}
  description={entry.data.metaDescription}
  pathWithoutLang={pathByLang}
  ogImagePath={ogImagePath}
  ogAvifPath={ogAvifPath}
  heroImagePath={heroImagePath}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="tool-page">
    <Breadcrumbs
      items={breadcrumbItems}
      ariaLabel={entry.data.language === 'de' ? 'Breadcrumb' : 'Breadcrumb navigation'}
    />
    <header class="tool-hero">
      <span class="eyebrow">
        <span class="eyebrow__dot" aria-hidden="true"></span>
        {eyebrowText}
      </span>
      {entry.data.headingHtml
        ? <h1 data-pagefind-weight="3" set:html={entry.data.headingHtml} />
        : <h1 data-pagefind-weight="3">{entry.data.title}</h1>
      }
      <p class="tagline">{entry.data.tagline}</p>
    </header>

    <p class="tool-intro-answer">{entry.data.intro}</p>

    {entry.data.stats && entry.data.stats.length > 0 && (
      <ToolStats stats={entry.data.stats} />
    )}

    <div class="tool-main">
      <div class="tool-main__primary">
        <section
          class:list={[
            'tool-section',
            (config.type === 'file-tool' ||
              config.type === 'comparer' ||
              config.type === 'interactive' ||
              config.id === 'image-diff' ||
              config.id === GROSS_NET_TOOL_ID) && 'tool-section--wide',
          ]}
          aria-label="Tool"
        >
          {config.type === 'converter' && (
            <Converter
              config={config}
              locale={entry.data.language === 'de' ? 'de-DE' : entry.data.language === 'en' ? 'en-US' : entry.data.language}
              client:load
            />
          )}
          {config.type === 'file-tool' && config.id === VIDEO_BG_REMOVE_TOOL_ID && (
            <VideoHintergrundEntfernenTool config={config} client:load />
          )}
          {config.type === 'file-tool' && config.id !== VIDEO_BG_REMOVE_TOOL_ID && (
            <FileTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === HEX_COLOR_TOOL_ID && (
            <ColorConverter config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === IMAGE_DIFF_TOOL_ID && (
            <BildDiffTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === QR_GENERATOR_TOOL_ID && (
            <QrCodeGeneratorTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === CONTRAST_CHECKER_TOOL_ID && (
            <ContrastCheckerTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === VAT_CALCULATOR_TOOL_ID && (
            <MehrwertsteuerRechnerTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === HOURLY_ANNUAL_TOOL_ID && (
            <StundenlohnJahresgehaltTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === AMORTIZATION_TOOL_ID && (
            <TilgungsplanRechnerTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === GROSS_NET_TOOL_ID && (
            <BruttoNettoRechnerTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === LOAN_CALCULATOR_TOOL_ID && (
            <KreditrechnerTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === DISCOUNT_CALCULATOR_TOOL_ID && (
            <RabattRechnerTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === INTEREST_CALCULATOR_TOOL_ID && (
            <ZinsrechnerTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === COMPOUND_INTEREST_TOOL_ID && (
            <ZinseszinsRechnerTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === ROI_CALCULATOR_TOOL_ID && (
            <RoiRechnerTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === CASH_DISCOUNT_TOOL_ID && (
            <SkontoRechnerTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === CASH_FLOW_TOOL_ID && (
            <CashflowRechnerTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === LEASING_FACTOR_TOOL_ID && (
            <LeasingFaktorRechnerTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === INHERITANCE_TAX_TOOL_ID && (
            <ErbschaftsteuerRechnerTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === 'ki-text-detektor' && (
            <KiTextDetektorTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === 'ki-bild-detektor' && (
            <KiBildDetektorTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === 'audio-transkription' && (
            <AudioTranskriptionTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === 'pdf-merge' && (
            <PdfZusammenfuehrenTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === 'pdf-split' && (
            <PdfAufteilenTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === 'pdf-to-jpg' && (
            <PdfZuJpgTool config={config} client:load />
          )}
          {config.type === 'formatter' && config.id === 'pdf-password' && (
            <PdfPasswortTool config={config} client:load />
          )}
          {config.type === 'formatter' && !CUSTOM_FORMATTER_IDS.has(config.id) && (
            <Formatter
              config={config}
              placeholder={config.placeholder ?? ''}
              inversePlaceholder={config.inversePlaceholder ?? ''}
              inverseLabel={config.inverseLabel ?? 'Decode'}
              client:load
            />
          )}
          {config.type === 'comparer' && (
            <Comparer
              config={config}
              placeholderA={config.placeholderA ?? ''}
              placeholderB={config.placeholderB ?? ''}
              client:load
            />
          )}
          {config.type === 'analyzer' && (
            <Analyzer
              config={config}
              placeholder={config.placeholder ?? ''}
              client:load
            />
          )}
          {config.type === 'generator' && <Generator config={config} client:load />}
          {config.type === 'validator' && config.id === REGEX_TESTER_TOOL_ID && (
            <RegexTesterTool config={config} client:load />
          )}
          {config.type === 'validator' && config.id !== REGEX_TESTER_TOOL_ID && (
            <Validator
              config={config}
              placeholder={config.placeholder ?? ''}
              client:load
            />
          )}
          {config.type === 'interactive' && config.id === WEBCAM_BLUR_TOOL_ID && (
            <WebcamBlurTool config={config} client:load />
          )}
        </section>

        {entry.data.kbdHints && entry.data.kbdHints.length > 0 && (
          <div class="kbd-hints" aria-hidden="true">
            {entry.data.kbdHints.map((hint: { key: string; label: string }) => (
              <kbd class="kbd-hint">
                <span class="kbd-hint__key">{hint.key}</span>
                <span class="kbd-hint__label">{hint.label}</span>
              </kbd>
            ))}
          </div>
        )}
      </div>

      {resolvedAside && (
        <details class="tool-aside" aria-labelledby="tool-aside-heading">
          <summary class="tool-aside__summary">
            <h2 id="tool-aside-heading">{strings.asideHeading}</h2>
            <svg class="tool-aside__chevron" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </summary>
          <div class="tool-aside__content">
            <section class="tool-aside__steps">
              <ol>
                {resolvedAside.steps.map((step: { title: string; description: string }, i: number) => (
                  <li>
                    <span class="tool-aside__step-number">
                      {String(i + 1).padStart(2, '0')}
                    </span>
                    <div class="tool-aside__step-body">
                      <h3>{step.title}</h3>
                      <p>{step.description}</p>
                    </div>
                  </li>
                ))}
              </ol>
            </section>
            <section class="tool-aside__privacy" aria-labelledby="tool-aside-privacy-heading">
              <h3 id="tool-aside-privacy-heading">Datenschutz</h3>
              <p>{resolvedAside.privacy}</p>
            </section>
          </div>
        </details>
      )}
    </div>

    <RelatedTools
      lang={entry.data.language}
      ownSlug={Astro.params.slug!}
      relatedSlugs={entry.data.relatedTools}
    />

    {/* Phase 2 aktiviert AdSense — der Slot reserviert schon jetzt die
        AdSense-Standard-Unit-Höhe (300×250 In-Content Rectangle via
        .ad-slot--in-content), damit späteres Einblenden keinen CLS
        erzeugt. Bis dahin visuell komplett leer (kein Rahmen, keine
        Beschriftung). aria-hidden + role="presentation" halten Screen-
        reader raus. Styles: src/styles/global.css → .ad-slot. */}
    <aside class="ad-slot ad-slot--in-content" aria-hidden="true" role="presentation"></aside>

    <article class="tool-article" data-pagefind-weight={pagefindArticleWeight}>
      <header class="section-head">
        <span class="section-head__label">{strings.howToSectionLabel}</span>
        <h2 class="section-head__title" set:html={strings.howToHeadingHtml} />
      </header>
      <ol class="how">
        {entry.data.howToUse.map((step: string) => <li>{step}</li>)}
      </ol>

      <div class="prose tool-article__prose">
        <Content />
      </div>

      {computedRelated.length > 0 && (
        <aside class="tool-article__related" aria-label={strings.relatedToolsHeading}>
          <h2 class="tool-article__related-heading">{strings.relatedToolsHeading}</h2>
          <ul class="tool-article__related-list">
            {computedRelated.map((t) => (
              <li>
                <a class="tool-article__related-link" href={t.href}>{t.shortTitle}</a>
              </li>
            ))}
          </ul>
        </aside>
      )}

      {dateModifiedFormatted && (
        <p class="tool-updated">
          {strings.lastUpdatedLabel}{' '}
          <time datetime={entry.data.dateModified}>{dateModifiedFormatted}</time>
        </p>
      )}
    </article>

    <YouMightAlsoLike
      lang={entry.data.language}
      currentToolId={entry.data.toolId}
      excludeSlugs={entry.data.relatedTools}
    />
  </div>
</BaseLayout>

<style>
  .tool-page {
    display: flex;
    flex-direction: column;
    padding-top: var(--space-12);
  }

  .tool-hero {
    max-width: 56rem;
    margin: 0 auto var(--space-12);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
  }
  .tool-hero h1 {
    margin: 0;
    /* Editorial scale — Single-Line-Ziel auf Desktop. Max 3.5rem (56px)
       hält den H1 einzeilig bei typischen Tool-Titeln und verhindert,
