---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getStaticPagePathRecord } from '../../lib/static-page-slugs';
---
<BaseLayout
  lang="en"
  title="Imprint – kittokit"
  description="Legal information for kittokit: operator details, contact, and disclaimers."
  pathWithoutLang={getStaticPagePathRecord('imprint')}
>
  <article class="legal">

    <header class="legal-header">
      <p class="legal-eyebrow">Legal</p>
      <h1>Imprint</h1>
    </header>

    <div class="legal-body">

      <!-- Non-commercial statement -->
      <section class="legal-section">
        <div class="legal-infobox">
          <p class="infobox-lead">Private, non-commercial hobby project</p>
          <p class="infobox-text">kittokit is operated by a private individual based in Germany as a hobby project — with no profit-making intention, no advertising revenue, no fees, and no commercial activity of any kind. All tools run entirely in your browser, with no file uploads and no tracking.</p>
          <p class="infobox-text">As this website does not constitute a "commercial" service within the meaning of §5 DDG (German Digital Services Act), there is no legal obligation to publish a full imprint. The details below are published voluntarily pursuant to §18(2) MStV (German Interstate Media Treaty).</p>
        </div>
      </section>

      <!-- Minimal contact info -->
      <section class="legal-section">
        <h2>Operator</h2>
        <dl class="legal-dl">
          <div class="legal-dl__row">
            <dt>Name</dt>
            <dd>Carina</dd>
          </div>
          <div class="legal-dl__row">
            <dt>Location</dt>
            <dd>Höxter, Germany</dd>
          </div>
          <div class="legal-dl__row">
            <dt>Email</dt>
            <dd><a href="mailto:hello@kittokit.com" class="legal-link">hello@kittokit.com</a></dd>
          </div>
        </dl>
        <p class="legal-note">Under §18(2) MStV, name and city of residence are sufficient — a full street address is not required for non-commercial private offerings.</p>
      </section>

      <!-- Dispute resolution -->
      <section class="legal-section">
        <h2>Dispute Resolution</h2>
        <p>The European Commission provides an online dispute resolution platform: <a href="https://ec.europa.eu/consumers/odr/" class="legal-link" rel="noopener noreferrer" target="_blank">ec.europa.eu/consumers/odr</a></p>
        <p>There is no obligation to participate in dispute resolution proceedings, as kittokit does not provide paid services.</p>
      </section>

      <!-- Liability -->
      <section class="legal-section">
        <h2>Disclaimer</h2>

        <h3>Liability for content</h3>
        <p>The content and tool results on this website have been prepared with the greatest possible care. No warranty is given for accuracy, completeness, or currency. Tool results are for general informational purposes only and do not substitute expert advice.</p>

        <h3>Liability for links</h3>
        <p>The respective operator is responsible for the content of linked external websites. Links will be removed promptly if an infringement becomes known.</p>

        <h3>Copyright</h3>
        <p>Content created by the operator is subject to German copyright law. Reproduction or distribution requires written consent.</p>
      </section>

    </div>
  </article>
</BaseLayout>

<style>
  .legal {
    max-width: 54rem;
    padding-top: var(--space-12);
  }
  .legal-header {
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-12);
  }
  .legal-eyebrow {
    font-family: var(--font-family-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin: 0 0 var(--space-3);
  }
  .legal h1 {
    font-size: var(--font-size-h1);
    font-weight: var(--font-fw-h1);
    line-height: var(--font-lh-h1);
    letter-spacing: var(--tracking-tighter);
    color: var(--color-text);
    margin: 0;
  }
  .legal-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    padding-bottom: var(--space-16);
  }
  .legal-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .legal h2 {
    font-size: var(--font-size-h3);
    font-weight: 600;
    line-height: var(--font-lh-h3);
    letter-spacing: var(--tracking-snug);
    color: var(--color-text);
    margin: 0;
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }
  .legal h3 {
    font-size: var(--font-size-body);
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
    margin-top: var(--space-4);
  }
  .legal p {
    font-size: var(--font-size-body);
    line-height: var(--font-lh-body);
    color: var(--color-text-muted);
    margin: 0;
  }
  .legal-link {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: var(--underline-offset);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .legal-link:hover { color: var(--color-accent-hover); }
  .legal-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: var(--r-sm);
  }
  .legal-note {
    font-size: var(--font-size-small);
    color: var(--color-text-subtle);
    font-style: italic;
    margin: 0;
  }
  .legal-dl {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--r-md);
    overflow: hidden;
  }
  .legal-dl__row {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }
  .legal-dl__row:last-child { border-bottom: none; }
  .legal-dl__row dt {
    font-size: var(--font-size-small);
    font-weight: 600;
    color: var(--color-text);
    padding-top: 0.1em;
  }
  .legal-dl__row dd {
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
    margin: 0;
    line-height: var(--font-lh-small);
  }
  .legal-infobox {
    background: var(--color-surface-sunk);
    border: 1px solid var(--color-border);
    border-radius: var(--r-md);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .infobox-lead {
    font-weight: 600;
    color: var(--color-text);
    font-size: var(--font-size-small);
    margin: 0;
  }
  .infobox-text {
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
    line-height: var(--font-lh-small);
    margin: 0;
  }
  @media (max-width: 40rem) {
    .legal h1 { font-size: var(--font-size-h2); }
    .legal-dl__row { grid-template-columns: 1fr; gap: var(--space-1); }
  }
</style>
