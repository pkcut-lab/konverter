---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolsIndex from '../../components/ToolsIndex.astro';
import { t } from '../../lib/i18n/strings';

const lang = 'de' as const;
const strings = t(lang);
---
<BaseLayout
  lang={lang}
  title={strings.toolsPageTitle}
  description={strings.toolsPageDescription}
  pathWithoutLang={{ de: '/werkzeuge', en: '/tools' }}
>
  <ToolsIndex lang={lang} />
</BaseLayout>
