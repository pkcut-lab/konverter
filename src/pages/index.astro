---
// Root language redirect — production is handled by the CF Pages Function
// (functions/index.js) which 302-redirects at the edge based on cookie →
// Accept-Language → DEFAULT_LANG. Users in production NEVER see this page.
//
// This static file fires when CF Functions are unavailable: local
// `astro dev` / `astro preview`, edge-cases where the function fails, or
// crawlers that bypass it. The earlier version of this file rendered as
// raw browser-default HTML (serif Times, blue underline links) for ~50–
// 200 ms before the meta-refresh kicked in — which looked like a broken
// page. This is the state-of-the-art fix (4-layer defense, 2026):
//
//   1. Synchronous inline <script> in <head>: location.replace() mirrors
//      the CF function logic (cookie → navigator.languages → DEFAULT_LANG)
//      and fires BEFORE first paint — no flash in 99 % of cases.
//   2. Inline critical <style>: brand-matched palette + system-ui font (no
//      FOUT). For the rare case the page DOES paint, it looks like a brief
//      brand splash, not an error.
//   3. <meta http-equiv="refresh"> 0 s: no-JS fallback.
//   4. Visible language picker: works without JS, without meta-refresh,
//      without anything — accessible final fallback.
//
// The SUPPORTED list, COOKIE_NAME and DEFAULT_LANG MUST stay in sync with
// functions/index.js so behaviour is identical between local dev and
// production. ACTIVE_LANGUAGES in src/lib/hreflang.ts is the upstream
// source-of-truth.
//
// Hex-Ausnahme: src/pages/** liegt NICHT unter dem Tokens-only-Hard-Cap
// (CLAUDE.md §5 — gilt für components/, layouts/, styles/tokens*.css).
// Inline-CSS hier ist Pflicht, sonst zerstören wir den Zero-Request-Vorteil
// dieses Fallbacks. Werte spiegeln tokens.css 1:1.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    {/*
      No `noindex` here. In production the CF Pages Function (functions/index.js)
      302-redirects every request to /de or /en before this static asset is ever
      served, so Googlebot follows the redirect and indexes the locale-prefixed
      page. The earlier `noindex` was defensive against a CF-Functions failure,
      but it created a worse failure mode: if the function ever did fail and the
      static fallback shipped, Google would honour the noindex on the apex —
      effectively de-indexing the brand root. The 4-layer redirect (synchronous
      JS, meta-refresh, visible language picker) is the safer fallback. We also
      drop the hard-coded `/en` canonical for the same reason — the apex is a
      router, not an indexing target. If you want robots to NOT crawl this file,
      use _headers `X-Robots-Tag: noindex` scoped to /index.html instead.
    */}
    <meta name="theme-color" content="#FAFAF9" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1A1917" media="(prefers-color-scheme: dark)" />
    <title>kittokit</title>

    {/* Layer 1 — synchronous inline redirect. Runs BEFORE the browser parses
        any of the body, so location.replace() preempts the first paint in
        every browser that has JS enabled. Mirrors functions/index.js. */}
    <script is:inline>
      (function () {
        try {
          var SUPPORTED = ['de', 'en'];
          var DEFAULT_LANG = 'en';
          var COOKIE_NAME = 'kittokit-lang';

          var match = document.cookie.match(
            new RegExp('(?:^|;\\s*)' + COOKIE_NAME + '=([^;]+)')
          );
          var lang = match ? decodeURIComponent(match[1]) : null;

          if (!lang || SUPPORTED.indexOf(lang) === -1) {
            var langs = navigator.languages || [navigator.language || ''];
            lang = null;
            for (var i = 0; i < langs.length; i++) {
              var code = (langs[i] || '').slice(0, 2).toLowerCase();
              if (SUPPORTED.indexOf(code) !== -1) {
                lang = code;
                break;
              }
            }
          }

          location.replace('/' + (lang || DEFAULT_LANG));
        } catch (e) {
          location.replace('/en');
        }
      })();
    </script>

    {/* Layer 3 — meta-refresh, no-JS fallback. */}
    <meta http-equiv="refresh" content="0;url=/en" />

    {/* Layer 2 — inline critical CSS so the rare visible paint is brand-correct. */}
    <style>
      :root {
        --bg: #fafaf9;
        --surface: #ffffff;
        --text: #1a1917;
        --text-muted: #52504b;
        --border: #e8e6e1;
        --accent: #8f3a0c;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #1a1917;
          --surface: #252320;
          --text: #fafaf9;
          --text-muted: #b3b0a9;
          --border: #3a3733;
          --accent: #f0a066;
        }
      }
      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        font-size: 16px;
        line-height: 1.6;
        display: grid;
        place-items: center;
        padding: 1.5rem;
      }
      main {
        max-width: 22rem;
        width: 100%;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text);
      }
      .brand-mark {
        display: inline-flex;
        color: var(--text);
      }
      .wordmark {
        font-size: 1.375rem;
        font-weight: 600;
        letter-spacing: -0.015em;
        white-space: nowrap;
      }
      .wordmark em {
        font-style: normal;
        color: var(--accent);
      }
      .hint {
        margin: 0;
        font-size: 0.875rem;
        color: var(--text-muted);
      }
      .picker {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        justify-content: center;
      }
      .picker a {
        display: inline-flex;
        align-items: center;
        padding: 0.5rem 1rem;
        background: var(--surface);
        color: var(--text);
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition: border-color 150ms ease, color 150ms ease;
      }
      .picker a:hover {
        border-color: var(--accent);
        color: var(--accent);
      }
      .picker a:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }
      @media (prefers-reduced-motion: reduce) {
        .picker a { transition: none; }
      }
    </style>
  </head>
  <body>
    <main>
      <div class="brand">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="28" height="28">
            <rect width="24" height="24" rx="6" fill="currentColor" />
            <polyline points="8,7 4,12 8,17" stroke="var(--bg)" stroke-width="1.5" fill="none" stroke-linejoin="round" stroke-linecap="round" />
            <line x1="12" y1="7" x2="12" y2="17" stroke="#f0a066" stroke-width="3" stroke-linecap="round" />
            <polyline points="20,7 16,12 20,17" stroke="var(--bg)" stroke-width="1.5" fill="none" stroke-linejoin="round" stroke-linecap="round" />
          </svg>
        </span>
        <span class="wordmark">kit<em>to</em>kit</span>
      </div>
      <p class="hint">Choose your language · Sprache wählen</p>
      {/* Layer 4 — accessible final fallback. */}
      <nav class="picker" aria-label="Language picker">
        <a href="/de" hreflang="de" lang="de">Deutsch</a>
        <a href="/en" hreflang="en" lang="en">English</a>
      </nav>
    </main>
  </body>
</html>
