---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getStaticPagePath } from '../lib/static-page-slugs';

const lang = (Astro.currentLocale ?? Astro.preferredLocale ?? 'de') as 'de' | 'en';
const toolsHref = getStaticPagePath('tools', lang);
const t =
  lang === 'en'
    ? {
        title: '404 — Page not found',
        heading: 'This page does not exist.',
        body: 'Maybe what you are looking for is in our tools.',
        cta: 'Browse tools',
        back: 'Back home',
      }
    : {
        title: '404 — Seite nicht gefunden',
        heading: 'Diese Seite gibt es nicht.',
        body: 'Vielleicht findest du was du suchst in unseren Werkzeugen.',
        cta: 'Zu den Werkzeugen',
        back: 'Zur Startseite',
      };
---

<BaseLayout lang={lang} title={t.title} pathWithoutLang="/404">
  <div class="error-page">
    <p class="eyebrow">404</p>
    <h1>{t.heading}</h1>
    <p class="body">{t.body}</p>
    <div class="actions">
      <a class="primary" href={toolsHref}>{t.cta}</a>
      <a class="ghost" href={`/${lang}`}>{t.back}</a>
    </div>
  </div>
</BaseLayout>

<style>
  .error-page {
    max-width: 32rem;
    margin: var(--space-16) auto;
    text-align: center;
  }
  .eyebrow {
    font-family: var(--font-family-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-subtle);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    margin: 0 0 var(--space-4);
  }
  h1 {
    font-size: var(--font-size-h1);
    margin: 0 0 var(--space-4);
    letter-spacing: var(--tracking-tighter);
  }
  .body {
    color: var(--color-text-muted);
    margin: 0 0 var(--space-8);
  }
  .actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
  .primary {
    background: var(--color-text);
    color: var(--color-bg);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--r-sm);
    text-decoration: none;
    font-size: var(--font-size-small);
    font-weight: 500;
  }
  .ghost {
    color: var(--color-text-muted);
    padding: var(--space-3) var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--r-sm);
    text-decoration: none;
    font-size: var(--font-size-small);
  }
</style>
