---
import '../styles/global.css';
import ThemeScript from '../components/ThemeScript.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.svelte';
import { buildHreflangLinks, DEFAULT_LANGUAGE, type ActiveLanguage } from '../lib/hreflang';
import { t } from '../lib/i18n/strings';
import type { Lang } from '../lib/tools/types';

interface Props {
  lang: string;
  title: string;
  description?: string;
  /** Either a single string (shared slug) OR a per-language record when slugs
   *  differ per language, e.g. `{ de: '/werkzeuge', en: '/tools' }`. */
  pathWithoutLang: string | Partial<Record<ActiveLanguage, string>>;
  /** Per-tool OG image path (e.g. '/og/tools/meter-zu-fuss.webp').
   *  Falls back to the site-wide '/og-image.png' when absent. */
  ogImagePath?: string | undefined;
}
const { lang, title, description, pathWithoutLang, ogImagePath } = Astro.props;
const strings = t(lang as Lang);
const hreflangs = buildHreflangLinks({ pathWithoutLang });

const canonicalPath: string =
  typeof pathWithoutLang === 'string'
    ? pathWithoutLang
    : (pathWithoutLang[lang as ActiveLanguage] ?? pathWithoutLang[DEFAULT_LANGUAGE] ?? '/');
const canonical = new URL(`/${lang}${canonicalPath}`, Astro.site).toString();
const ogImage = new URL(ogImagePath ?? '/og-image.png', Astro.site).toString();

// Site-wide entity signals — Organization + WebSite + SearchAction.
// Emitted on every page (not just tool pages) so the brand-entity is
// reinforced consistently. Per-tool JSON-LD (SoftwareApplication +
// BreadcrumbList + FAQPage + HowTo) lives in `[lang]/[slug].astro` and
// stacks on top of these blocks. Pagefind powers the SearchAction
// endpoint at runtime — the URL pattern points at the home page with
// a `?q=` query string the home page can intercept (Phase 2 will wire
// the actual search-results page; today it falls through to the
// HeaderSearch component which reads `?q` if present).
const cfRumToken = import.meta.env.CF_RUM_TOKEN;
const clarityId = import.meta.env.PUBLIC_CLARITY_PROJECT_ID;

const siteUrl = Astro.site!.toString().replace(/\/$/, '');
const siteName = 'kittokit';
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteName,
  url: siteUrl,
  logo: `${siteUrl}/icon-512.png`,
  description: strings.orgDescription,
  sameAs: [
    'https://github.com/pkcut-lab',
  ],
};
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: siteUrl,
  inLanguage: lang,
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${siteUrl}/${lang}/?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index,follow,max-image-preview:large" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="kittokit" />
    <meta property="og:locale" content={lang === 'de' ? 'de_DE' : lang === 'en' ? 'en_US' : lang} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={strings.ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={strings.ogImageAlt} />

    <ThemeScript />

    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="kittokit" />
    <meta name="application-name" content="kittokit" />

    {/* Preload ONLY the fonts on the critical path. Inter carries body copy,
        JetBrains Mono carries meta labels + numerics visible on first paint.
        Playfair Display is decorative (<em> inside H1/H2 only) — `font-display:
        swap` renders the fallback italic immediately and swaps when ready.
        Preloading Playfair burns ~38 KB for a glyph the user barely sees above
        the fold on most tool pages. */}
    <link
      rel="preload"
      href="/fonts/Inter-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/JetBrainsMono-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    {hreflangs.map((l) => (
      <link rel="alternate" hreflang={l.hreflang} href={l.href} />
    ))}

    {/* Site-wide structured data: Organization + WebSite (with SearchAction).
        Per-page JSON-LD (SoftwareApplication, FAQPage, HowTo, BreadcrumbList)
        is injected by the slug route on top of these. */}
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />

    {/* Preconnect to third-party origins used by analytics so the
        TCP+TLS handshake completes before the deferred scripts fire. */}
    <link rel="preconnect" href="https://static.cloudflareinsights.com" />
    <link rel="dns-prefetch" href="https://www.clarity.ms" />

    {/* Service Worker registration — generated by @vite-pwa/astro.
        `defer` keeps it off the critical path; the SW only claims control
        on the next navigation anyway. No-op during `astro dev`. */}
    <script is:inline defer src="/registerSW.js"></script>
  </head>
  <body>
    <Header lang={lang} langAlternates={hreflangs} />
    <main class="site-main" data-pagefind-body>
      <slot />
    </main>
    <Footer lang={lang} />
    <CookieBanner client:idle />

    {/* Cloudflare Web Analytics — privacy-first, no consent required */}
    {cfRumToken && (
      <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={`{"token":"${cfRumToken}"}`}></script>
    )}

    {/* Microsoft Clarity — consent-gated, loads only when statistik=true */}
    {clarityId && (
      <script is:inline define:vars={{clarityId}}>
        if (typeof window !== 'undefined') {
          var _clarityLoad = function () {
            try {
              var c = JSON.parse(localStorage.getItem('kittokit-consent') || 'null');
              if (c && c.statistik && !window.clarity) {
                (function (c, l, a, r, i, t, y) {
                  c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
                  t = l.createElement(r); t.async = 1; t.src = 'https://www.clarity.ms/tag/' + i;
                  y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
                })(window, document, 'clarity', 'script', clarityId);
              }
            } catch (e) {}
          };
          _clarityLoad();
          window.addEventListener('kittokit-consent-change', _clarityLoad);
        }
      </script>
    )}
  </body>
</html>

<style>
  .site-main {
    max-width: 72rem;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6);
  }
</style>
