# Cloudflare Pages response headers.
# Syntax: https://developers.cloudflare.com/pages/configuration/headers/
# Files under public/ are copied to the deploy root verbatim — this file
# lives next to manifest.webmanifest and gets applied at the edge.

# Baseline security posture for every response. HSTS is safe because
# *.pages.dev is HTTPS-only anyway; the preload list isn't relevant for
# a subdomain we don't own the apex of.
#
# Content-Security-Policy (2026-04-21, Q2 Option 1):
#   - 'unsafe-inline' für script-src: ThemeScript.astro emittiert einen
#     inline Flash-Prevention-Block. Phase-2-Migration zu Nonce-basierter
#     Policy (Q2 Option 3) wenn Zeit ist; jetzt ist die Gain-vs-Cost-Ratio
#     für unsafe-inline-ersatz schlecht (ein einziges Inline-Script, das
#     kein Nutzer-Input annimmt).
#   - 'unsafe-inline' für style-src: Astro's scoped-style-Mechanismus +
#     Svelte-Runtime-style-Injection erzeugen inline <style>-Blöcke.
#   - connect-src 'self' + Huggingface-CDNs: `remove-background` (ONNX-
#     Model-Download) und `hevc-zu-h264` (Transformers.js) brauchen
#     https://huggingface.co + cdn-lfs.huggingface.co. Spec Section 7a
#     ML-Worker-Exception.
#   - worker-src 'self' blob:: @vite-pwa/astro plus Worker-Boundary in
#     File-Tools (blob:-URLs für dynamisch instantiierte Worker).
#   - frame-ancestors 'none': Clickjacking-Hard-Stop.
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(), geolocation=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' https://huggingface.co https://cdn-lfs.huggingface.co; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'

# Service Worker must never be cached by the browser itself — otherwise
# users get stuck on an old build even after Workbox skipWaiting fires.
# The SW still caches the app shell internally; the HTML request for
# /sw.js just needs to always hit the origin.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/registerSW.js
  Cache-Control: no-cache

# Astro emits hashed filenames under _astro/ — safe to cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts are content-hashed-by-name (Inter-Variable.woff2 stays
# the same file); long cache is fine because the filename changes when
# we swap families.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Pagefind index + UI chunks: the search can tolerate a few-minute stale
# window; the SW also has StaleWhileRevalidate, so this is belt-and-
# suspenders for non-SW (first-load) requests.
/pagefind/*
  Cache-Control: public, max-age=3600

# OG images are hashed by content (og/tools/*.webp); long cache is safe.
/og/*
  Cache-Control: public, max-age=31536000, immutable

# Icons: change rarely; one-day cache is acceptable.
/icon*.png
  Cache-Control: public, max-age=86400

/icon*.svg
  Cache-Control: public, max-age=86400

# Manifest + favicon: short cache so re-branding reaches users fast.
/manifest.webmanifest
  Cache-Control: public, max-age=3600

/favicon-32.png
  Cache-Control: public, max-age=86400

/icon.svg
  Cache-Control: public, max-age=86400
