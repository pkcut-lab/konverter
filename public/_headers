# Cloudflare Pages response headers.
# Syntax: https://developers.cloudflare.com/pages/configuration/headers/
# Files under public/ are copied to the deploy root verbatim — this file
# lives next to manifest.webmanifest and gets applied at the edge.

# Baseline security posture for every response.
#
# HSTS (2026-04-26): upgraded to 2-year max-age + preload for HSTS preload
# list submission on custom domains (kittokit.com/.de/.tools).
# On *.pages.dev HTTPS is forced at CF edge regardless.
#
# X-Frame-Options: DENY (2026-04-26): defense-in-depth for legacy browsers
# that don't honour CSP frame-ancestors. Modern browsers use frame-ancestors
# 'none' from CSP below; both together cover the full browser matrix.
#
# Content-Security-Policy:
#   - script-src hashes: replaced by scripts/patch-csp-hashes.mjs in
#     dist/_headers after each build (NOT this source file). 'unsafe-
#     inline' removed; hashes cover all inline <script> blocks
#     (ThemeScript + Header lang-cookie + Clarity loader).
#     public/_headers stays as a template — keep the placeholder token
#     intact (single occurrence below) or the postbuild script hard-fails.
#   - 'unsafe-inline' für style-src: Astro's scoped-style-Mechanismus +
#     Svelte-Runtime-style-Injection erzeugen inline <style>-Blöcke.
#   - connect-src 'self' + Huggingface-CDNs: remove-background (ONNX) +
#     hevc-zu-h264 (Transformers.js). Spec Section 7a ML-Worker-Exception.
#     Hugging Face migrated large-file delivery from cdn-lfs.huggingface.co
#     to *.xethub.hf.co (XetHub CDN) in 2026 — the model URL is on
#     huggingface.co but a 302 redirects to e.g. cas-bridge.xethub.hf.co.
#     Both hosts must be on the connect-src allow-list or the redirect is
#     blocked and the model download fails with `no-response` after the
#     ServiceWorker swallows the rejection. Wildcard `*.xethub.hf.co`
#     covers cas-bridge plus any future XetHub subdomains HF rolls out.
#   - ONNX-Runtime self-hosted: `scripts/copy-ort-web.mjs` copies the
#     `ort-wasm-simd-threaded.{,asyncify,jsep,jspi}.{mjs,wasm}` runtime
#     files from `node_modules/onnxruntime-web/dist/` into `dist/ort/`
#     at build-time. `applyOrtSelfHost(env)` in `ml-mirror.ts` points
#     `env.backends.onnx.wasm.wasmPaths` to `/ort/` so Transformers.js v4
#     fetches the runtime from our origin instead of `cdn.jsdelivr.net`.
#     Result: no third-party CDN in script-src or connect-src; CSP stays
#     tight; ML tools stop depending on a single jsdelivr point-of-failure.
#   - media-src 'self' blob:: AudioTranskriptionTool creates blob: URLs via
#     URL.createObjectURL() for the in-page audio preview player. Without
#     this directive, default-src 'self' blocks the blob: URL and the player
#     silently fails to load the uploaded audio before transcription.
#   - worker-src 'self' blob:: @vite-pwa/astro + File-Tool Worker-Boundary.
#   - frame-ancestors 'none': Clickjacking-Hard-Stop.
#   - COOP same-origin (2026-04-26): closes Spectre-class side-channels.
#   - Permissions-Policy (2026-04-26): browsing-topics, interest-cohort,
#     attribution-reporting, usb, serial, bluetooth explicitly blocked.
/*
  Link: </.well-known/api-catalog>; rel="api-catalog", </.well-known/agent-skills/index.json>; rel="https://agentskills.io/rel/skills-index"
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin
  Permissions-Policy: camera=(self), microphone=(self), geolocation=(), payment=(), browsing-topics=(), interest-cohort=(), attribution-reporting=(), usb=(), serial=(), bluetooth=()
  Content-Security-Policy: default-src 'self'; script-src 'self' https://static.cloudflareinsights.com https://www.clarity.ms __CSP_SCRIPT_HASHES__; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; media-src 'self' blob:; font-src 'self' data:; connect-src 'self' https://huggingface.co https://cdn-lfs.huggingface.co https://*.xethub.hf.co https://*.clarity.ms https://cloudflareinsights.com; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'

# Service Worker must never be cached by the browser itself — otherwise
# users get stuck on an old build even after Workbox skipWaiting fires.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/registerSW.js
  Cache-Control: no-cache

# Astro emits hashed filenames under _astro/ — safe to cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts are content-hashed-by-name; long cache is fine.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# ONNX-Runtime-Web runtime files (.wasm + .mjs) — version-pinned via
# `package.json` → onnxruntime-web semver. New version = new file content
# = SW + browser cache invalidates on next build. Long cache is safe.
/ort/*
  Cache-Control: public, max-age=31536000, immutable

# Pagefind: StaleWhileRevalidate for non-SW first-load requests.
/pagefind/*
  Cache-Control: public, max-age=3600

# OG images: content-keyed by slug, long cache is safe.
/og/*
  Cache-Control: public, max-age=31536000, immutable

/icon*.png
  Cache-Control: public, max-age=86400

/icon*.svg
  Cache-Control: public, max-age=86400

/manifest.webmanifest
  Cache-Control: public, max-age=3600

/favicon-32.png
  Cache-Control: public, max-age=86400

/icon.svg
  Cache-Control: public, max-age=86400

# Agent-readiness: correct Content-Type for well-known discovery endpoints.
/.well-known/api-catalog
  Content-Type: application/linkset+json

/.well-known/agent-skills/index.json
  Content-Type: application/json

/.well-known/agent-skills/skills/*.json
  Content-Type: application/json
