# Dependencies
node_modules/

# Build
dist/
.astro/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.local
.env.*.local

# Logs
npm-debug.log*
*.log

# Pagefind Index (generated)
public/pagefind/

# Husky runtime
.husky/_/

# Cloudflare
.wrangler/

# Stitch downloads (HTML + screenshots aus @google/stitch-sdk)
stitch-output/

# Eval transients (JSON-Ergebnisse der Critic-Smokes, lokal regenerierbar)
evals/*/last-*-result.txt

# Paperclip runtime flags (EMERGENCY_HALT etc. — per-workspace, nicht im repo)
.paperclip/

# User-local skill caches (adapter/animate/audit/... — global installed, nicht repo-versioned)
.agents/
.claude/
.kiro/

# Audit artifacts (Screenshots, Reports — volatile, >20 MB, lokal regenerierbar)
audit/

# Local git-account-override (liegt nur rum, nicht via include.path aktiv)
.gitconfig-konverter

# Generated skill-lockfile
skills-lock.json

# Paperclip runtime task-artifacts (volatile, large historical critic outputs)
tasks/awaiting-critics/_processed/
tasks/.ceo-tmp/
