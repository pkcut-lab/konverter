# Dependencies
node_modules/

# Build
dist/
.astro/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.local
.env.*.local

# Logs
npm-debug.log*
*.log

# Pagefind Index (generated)
public/pagefind/

# Husky runtime
.husky/_/

# Cloudflare
.wrangler/

# Stitch downloads (HTML + screenshots aus @google/stitch-sdk)
stitch-output/

# Eval transients (JSON-Ergebnisse der Critic-Smokes, lokal regenerierbar)
evals/*/last-*-result.txt

# Paperclip runtime flags (EMERGENCY_HALT etc. — per-workspace, nicht im repo)
.paperclip/

# User-local skill caches (adapter/animate/audit/... — global installed, nicht repo-versioned)
.agents/
.claude/
.kiro/

# Audit artifacts (Screenshots, Reports — volatile, >20 MB, lokal regenerierbar)
audit/

# Local git-account-override (liegt nur rum, nicht via include.path aktiv)
.gitconfig-konverter

# Generated skill-lockfile
skills-lock.json

# Paperclip runtime task-artifacts (volatile, large historical critic outputs)
tasks/awaiting-critics/_processed/
tasks/.ceo-tmp/

# Vitest config cache (regenerated per-run)
vitest.config.ts.timestamp-*.mjs

# Lighthouse run artifacts (per-session, large, regenerable)
lh-*.json

# Obsidian vault config (user-local, machine-specific)
.obsidian/

# Graphify intermediates (chunks + cache regenerable via `graphify update .`)
graphify-out/.graphify_chunk_*.json
graphify-out/cache/

# Agent activity logs (per-heartbeat append, rotated separately)
memory/*-log.md
memory/halt-history.md
memory/error-register.md

# Per-ticket review artifacts (volatile, archived to _processed/ post-ship)
tasks/meta-review-*.md
inbox/processed/
tasks/dossier-output-*.md
tasks/awaiting-critics/
tasks/digest/
tasks/dossier-locks/
tasks/end-review-*.md
tasks/engineer_output_*.md
tasks/dossiers/
inbox/daily-digest/

# Stitch screenshots (renderer output, regenerable)
docs/paperclip/research/2026-04-21-local-cli-destructive-symlink-removal.md.stitch/

# Playwright test artifacts (per-run, large, regenerable)
test-results/
tests/a11y/results.json

# Lighthouse CI output
.lhci-output/

# Raw audit JSON (committed as .md summaries instead)
audits/*.json
audits/playwright-results.json
