# Auto-detect text files and normalize line endings to LF on commit.
# This prevents CRLF-related test breakage on Windows checkouts (Git core.autocrlf=true
# would otherwise inject CRLF into text files, breaking raw byte-level regex matches).
* text=auto eol=lf

# Source code — always LF regardless of OS
*.astro       text eol=lf
*.svelte      text eol=lf
*.ts          text eol=lf
*.tsx         text eol=lf
*.js          text eol=lf
*.mjs         text eol=lf
*.cjs         text eol=lf
*.jsx         text eol=lf
*.json        text eol=lf
*.css         text eol=lf
*.scss        text eol=lf
*.html        text eol=lf
*.md          text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.toml        text eol=lf
*.sh          text eol=lf

# Windows-native scripts stay CRLF (they need it to run)
*.bat         text eol=crlf
*.cmd         text eol=crlf
*.ps1         text eol=crlf

# Binary — never touched
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.webp        binary
*.avif        binary
*.ico         binary
*.pdf         binary
*.zip         binary
*.gz          binary
*.woff        binary
*.woff2       binary
*.ttf         binary
*.otf         binary
*.eot         binary
