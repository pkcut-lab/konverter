# Template — kopiere nach .env und trage reale Keys ein.
# .env ist gitignored, diese Template-Datei wird committed.

STITCH_API_KEY=your_stitch_key_here
FIRECRAWL_API_KEY=your_firecrawl_key_here
FIRECRAWL_WEBHOOK_SIGNING_KEY=your_firecrawl_webhook_signing_key_here

# Cloudflare Web Analytics (privacy-first, no consent needed)
# Dashboard: cloudflare.com → Web Analytics → Add a site → copy beacon token
CF_RUM_TOKEN=your_cf_rum_token_here

# Microsoft Clarity (consent-gated — only loads with statistik consent)
# Dashboard: clarity.microsoft.com → New project → copy Project ID
PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id_here
